// Unique short-category names, alphabetical — powers the left-side domain
// list in CataloguePanel (click to filter CATALOGUE by p.category === domain).
export const DOMAINS: string[] = Array.from(
  new Set(CATALOGUE.map((p) => p.category))
).sort((a, b) => a.localeCompare(b));
